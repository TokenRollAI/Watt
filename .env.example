# Watt — .env.example（结构模板；复制为 .env 并填入你自己的值。绝不提交真实 .env）。
#
# 两条部署路径：
#   - repo 路径（贡献者）：pnpm deploy:all，需下列 CLOUDFLARE_* + 密钥（wrangler secret / .dev.vars）。
#   - npm 路径（终端用户）：npx @token-roll/watt init，向导会交互式收集并经 wrangler secret put/SecretStore
#     写入，无需手工维护本文件（仅 CLOUDFLARE_API_TOKEN / CLOUDFLARE_ACCOUNT_ID 可经 env 传入）。
#
# 密钥分层（详见 Docs/Architecture.md 部署章节）：
#   信任根三 secret（gateway wrangler secret）：WATT_JWT_PRIVATE_JWK / WATT_SECRET_ENCRYPTION_KEY / WATT_ADMIN_PRINCIPAL。
#   业务密钥（runtime 化，经 SecretStore /htbp/platform/secret 写入 KV，非本文件）：LLM key 等。
#   飞书凭据随 watt-plugin-feishu Worker 自持（其 wrangler secret，非 gateway、非本文件）。

# ── Cloudflare 部署凭据（provision + wrangler deploy 的子进程 env；永不进 Worker 运行时）──────
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# R2 S3 兼容凭据（可选；仅 S3 API 直连 R2 时用）
CLOUDFLARE_R2_SECRET_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_KEY=your-r2-secret-access-key
R2_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# ── 平台基址 ────────────────────────────────────────────────────────────────────────
# gateway 对外 URL（custom domain 或 workers.dev）。CLI 从 WATT_BASE_URL 取平台入口。
WATT_BASE_URL=https://your-gateway.example.workers.dev
# JWKS 传播判据/验收脚本用（sign-admin-token.mjs --jwks-base 的 env 形态；勿复用被 DNS 污染的域名）。
WATT_JWKS_BASE_URL=https://your-gateway.example.workers.dev

# ── 信任根（gateway wrangler secret；本地 wrangler dev 经 .dev.vars 白名单，见 gen-dev-vars.mjs）──
# 初始 admin principal（种子引导，§6.5c）。
WATT_ADMIN_PRINCIPAL=user:admin
# 平台 Ed25519 私钥 JWK（生产走 `node scripts/gen-jwt-keys.mjs | wrangler secret put WATT_JWT_PRIVATE_JWK`；
#   或 watt init 本地生成后 secret put 并丢弃）。本地开发才填 .dev.vars 的专用测试密钥。
# WATT_JWT_PRIVATE_JWK={"kty":"OKP","crv":"Ed25519","x":"...","d":"..."}
# SecretStore AES-256-GCM 主密钥（32B base64url；生成：node -e "process.stdout.write(require('crypto').randomBytes(32).toString('base64url'))"）。
# WATT_SECRET_ENCRYPTION_KEY=your-32-byte-base64url-key

# ── 模型（provider registry / @llm agent；生产 LLM key 建议走 SecretStore，非本文件）─────────
WATT_DEFAULT_MODEL=claude-sonnet-4
WATT_FALLBACK_MODEL=claude-haiku-4
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_BASE_URL=https://api.anthropic.com
OPENAI_API_KEY=your-openai-api-key
# Cloudflare AI Gateway（可选；经 AI Gateway 代理模型调用）
CF_AI_GATEWAY_SLUG=your-ai-gateway-slug
CF_AI_GATEWAY_CUSTOM_PROVIDER=your-custom-provider
CF_AI_GATEWAY_TOKEN=your-ai-gateway-token

# ── 飞书 plugin（随 watt-plugin-feishu Worker 自持；此处仅本地 WS dev / 参考）──────────────────
# FEISHU_CONNECT_MODE=webhook   # webhook（生产，plugin worker）| ws（本地长连接开发）
FEISHU_WEBHOOK_URL=https://your-plugin-feishu.example.workers.dev/webhook/event
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_VERIFICATION_TOKEN=your-feishu-verification-token
FEISHU_ENCRYPT_KEY=your-feishu-encrypt-key

# ── E2E 验收（可选；仅跑 scripts/e2e 时需要）────────────────────────────────────────────
E2E_FEISHU_TEST_CHAT_ID=oc_your_test_chat_id
E2E_FEISHU_ADMIN_OPEN_ID=ou_your_admin_open_id
E2E_FEISHU_EMPLOYEE_OPEN_ID=ou_your_employee_open_id
E2E_WEBHOOK_SINK_URL=https://your-webhook-sink.example.com
